# Document Extraction Platform - Environment Variables

# =============================================================================
# LLM Configuration
# =============================================================================

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Azure OpenAI (Optional - if using Azure-hosted models)
USE_AZURE_OPENAI=false
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Cohere (Optional - for reranking in contextual retrieval)
CO_API_KEY=your-cohere-api-key
CO_RERANK_ENDPOINT=https://api.cohere.ai/v1/rerank

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
DJANGO_DATABASE_URL=postgres://uu:uu@postgres:5432/uu_django

# For local development (outside Docker)
# DJANGO_DATABASE_URL=postgres://uu:uu@localhost:5432/uu_django

# =============================================================================
# Redis Configuration
# =============================================================================

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# For local development (outside Docker)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# Django Configuration
# =============================================================================

# Django Settings Module
DJANGO_SETTINGS_MODULE=uu_backend.django_project.settings.local

# Debug Mode (set to false in production)
DEBUG=false

# Secret Key (generate a secure key for production)
# DJANGO_SECRET_KEY=your-secret-key-here

# Allowed Hosts (comma-separated)
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# API Configuration
# =============================================================================

# Backend API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend API URL (used by frontend to connect to backend)
VITE_API_URL=http://localhost:8000

# =============================================================================
# Contextual Retrieval Configuration
# =============================================================================

# Chunk size for document splitting
CHUNK_SIZE=4000

# Overlap between chunks
CHUNK_OVERLAP=800

# Maximum concurrency for parallel processing
MAX_CONCURRENCY=40

# Model for context generation
CONTEXT_MODEL=gpt-4o-mini

# =============================================================================
# ChromaDB Configuration
# =============================================================================

# ChromaDB persistence directory
CHROMA_PERSIST_DIRECTORY=/app/data/chroma

# =============================================================================
# File Storage
# =============================================================================

# File storage path (inside container)
FILE_STORAGE_PATH=/app/data/files

# =============================================================================
# CI/CD Configuration (for GitHub Actions)
# =============================================================================

# Codecov token (optional - for coverage reporting)
# CODECOV_TOKEN=your-codecov-token

# Container registry (GitHub Container Registry)
# REGISTRY=ghcr.io
# IMAGE_NAME=your-username/data-labeller

# =============================================================================
# Development Configuration
# =============================================================================

# Enable hot reload for development
# WATCHFILES_FORCE_POLLING=true

# Log level
# LOG_LEVEL=INFO

# =============================================================================
# Production Configuration
# =============================================================================

# Set these in production:
# - Generate a strong DJANGO_SECRET_KEY
# - Set DEBUG=false
# - Configure DJANGO_ALLOWED_HOSTS
# - Use strong database passwords
# - Enable HTTPS
# - Configure proper CORS settings
# - Set up monitoring and logging
# - Configure backup strategy

# =============================================================================
# Notes
# =============================================================================

# 1. Copy this file to .env and fill in your values
# 2. Never commit .env to version control
# 3. Use different values for development, staging, and production
# 4. Rotate API keys and secrets regularly
# 5. Use environment-specific configuration files
